<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pokemon App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark mb-4">
      <div class="container">
        <%= link_to "Pokémon App", pokemons_path, class: "navbar-brand" %>

        <div>
          <%= link_to "Home", pokemons_path, class: "btn btn-outline-light me-2" %>
          <%= link_to "About", about_path, class: "btn btn-outline-light" %>
        </div>
      </div>
    </nav>

    <main class="container">
      <%= yield %>
    </main>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js">
    </script>
  </body>
</html>