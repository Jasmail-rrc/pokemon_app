<%= form_with url: pokemons_path, method: :get, local: true do %>
  <%= text_field_tag :search, params[:search], placeholder: "Search Pokémon" %>
  <%= submit_tag "Search" %>
<% end %>
<h1>Pokémon List</h1>

<% @pokemons.each do |pokemon| %>
  <div>
    <h3><%= link_to pokemon.name.titleize, pokemon_path(pokemon) %></h3>
    <p>Type: <%= pokemon.type.name.titleize %></p>
    <% if pokemon.image_url.present? %>
      <%= image_tag pokemon.image_url %>
    <% end %>
  </div>
<% end %>

<%= paginate @pokemons %>
